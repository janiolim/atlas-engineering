---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import { withBase } from '../lib/url';

// 1. Busca todos os trabalhos e ordena
const allWorks = (await getCollection('works')).sort((a, b) => {
  const byDate = b.data.publishDate.getTime() - a.data.publishDate.getTime();
  return byDate || (a.data.order ?? 999) - (b.data.order ?? 999);
});

// 2. Filtra pelas categorias (arquitetura escalável)
const engineering = allWorks.filter((work) => work.data.category === 'engineering');
const research = allWorks.filter((work) => work.data.category === 'research');
const theory = allWorks.filter((work) => work.data.category === 'theory');

// Não alterado
const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);

// Não alterado
const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('en', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  }).format(date);
---

<BaseLayout 
  title="Início"
  description="Atlas é um portfólio técnico focado em engenharia elétrica, eletrônica aplicada, física experimental e sistemas embarcados."
>
  <section class="hero section">
    <p class="eyebrow">Engenharia elétrica / Física aplicada / Sistemas embarcados</p>

    <h1>Atlas — estrutura técnica para construção de ideias reais.</h1>

    <p class="lead">
      Um espaço para documentar projetos em eletrônica, experimentos em física e desenvolvimento de sistemas embarcados,
      com foco em clareza, método e evolução contínua.
    </p>

    <div class="action-row" aria-label="Primary links">
      <a class="button" href={withBase('/works/')}>Ver projetos</a>
      <a class="text-link" href={withBase('/blog/')}>Notas técnicas</a>
    </div>
  </section>

  <section class="section split-overview" aria-label="Theme overview">
    <div>
      <p class="eyebrow">Princípios</p>
      <h2>Clareza técnica acima de estética vazia.</h2>
    </div>

    <div class="feature-list">
      <article>
        <h3>Ritmo estrutural</h3>
        <p>Organização visual pensada para leitura longa e documentação técnica.</p>
      </article>

      <article>
        <h3>Projetos reais</h3>
        <p>Experimentos, sistemas e estudos aplicados em engenharia e física.</p>
      </article>

      <article>
        <h3>Evolução contínua</h3>
        <p>Registro progressivo de aprendizado técnico e desenvolvimento prático.</p>
      </article>
    </div>
  </section>

  <section class="section index-feed" aria-labelledby="engineering-works">
    <div class="section-heading">
      <p class="eyebrow">Engenharia</p>
      <h2 id="engineering-works">Engenharia e Impacto.</h2>
      <a class="text-link" href={withBase('/works/')}>Ver todos</a>
    </div>

    {
      engineering.length > 0 ? (
        <div class="highlight-grid">
          {engineering.map((work) => (
            <article class="highlight-card">
              {work.data.thumbnail && (
                <Image
                  src={work.data.thumbnail}
                  alt=""
                  width={720}
                  height={480}
                  loading="lazy"
                />
              )}

              <div>
                <p class="meta">{formatDate(work.data.publishDate)}</p>

                <h3>
                  <a href={withBase(`/works/${work.id}/`)}>
                    {work.data.title}
                  </a>
                </h3>

                <p>{work.data.description}</p>

                {work.data.tech.length > 0 && (
                  <ul class="tag-list" aria-label={`${work.data.title} tecnologia`}>
                    {work.data.tech.slice(0, 4).map((tech) => (
                      <li>{tech}</li>
                    ))}
                  </ul>
                )}
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="empty-state compact">
          <p>Adicione projetos de engenharia em <code>src/content/works</code> definindo <code>category: engineering</code>.</p>
        </div>
      )
    }
  </section>

  <section class="section index-feed" aria-labelledby="research-works">
    <div class="section-heading">
      <p class="eyebrow">Pesquisa</p>
      <h2 id="research-works">Pesquisa e Materiais.</h2>
      <a class="text-link" href={withBase('/works/')}>Ver todos</a>
    </div>

    {
      research.length > 0 ? (
        <div class="highlight-grid">
          {research.map((work) => (
            <article class="highlight-card">
              {work.data.thumbnail && (
                <Image
                  src={work.data.thumbnail}
                  alt=""
                  width={720}
                  height={480}
                  loading="lazy"
                />
              )}

              <div>
                <p class="meta">{formatDate(work.data.publishDate)}</p>

                <h3>
                  <a href={withBase(`/works/${work.id}/`)}>
                    {work.data.title}
                  </a>
                </h3>

                <p>{work.data.description}</p>

                {work.data.tech.length > 0 && (
                  <ul class="tag-list" aria-label={`${work.data.title} tecnologia`}>
                    {work.data.tech.slice(0, 4).map((tech) => (
                      <li>{tech}</li>
                    ))}
                  </ul>
                )}
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="empty-state compact">
          <p>Adicione projetos de pesquisa em <code>src/content/works</code> definindo <code>category: research</code>.</p>
        </div>
      )
    }
  </section>

  <section class="section index-feed" aria-labelledby="theory-works">
    <div class="section-heading">
      <p class="eyebrow">Teoria</p>
      <h2 id="theory-works">Teoria Física.</h2>
      <a class="text-link" href={withBase('/works/')}>Ver todos</a>
    </div>

    {
      theory.length > 0 ? (
        <div class="highlight-grid">
          {theory.map((work) => (
            <article class="highlight-card">
              {work.data.thumbnail && (
                <Image
                  src={work.data.thumbnail}
                  alt=""
                  width={720}
                  height={480}
                  loading="lazy"
                />
              )}

              <div>
                <p class="meta">{formatDate(work.data.publishDate)}</p>

                <h3>
                  <a href={withBase(`/works/${work.id}/`)}>
                    {work.data.title}
                  </a>
                </h3>

                <p>{work.data.description}</p>

                {work.data.tech.length > 0 && (
                  <ul class="tag-list" aria-label={`${work.data.title} tecnologia`}>
                    {work.data.tech.slice(0, 4).map((tech) => (
                      <li>{tech}</li>
                    ))}
                  </ul>
                )}
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="empty-state compact">
          <p>Adicione projetos teóricos em <code>src/content/works</code> definindo <code>category: theory</code>.</p>
        </div>
      )
    }
  </section>

  <section class="section index-feed" aria-labelledby="latest-notes">
    <div class="section-heading">
      <p class="eyebrow">Notas técnicas</p>
      <h2 id="latest-notes">Registro de estudo.</h2>
      <a class="text-link" href={withBase('/blog/')}>Ver todos</a>
    </div>

    {
      posts.length > 0 ? (
        <div class="note-list">
          {posts.map((post) => (
            <article class="note-row">
              {post.data.heroImage && (
                <Image
                  src={post.data.heroImage}
                  alt=""
                  width={320}
                  height={220}
                  loading="lazy"
                />
              )}

              <div>
                <p class="meta">{formatDate(post.data.publishDate)}</p>

                <h3>
                  <a href={withBase(`/blog/${post.id}/`)}>
                    {post.data.title}
                  </a>
                </h3>

                <p>{post.data.description}</p>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="empty-state compact">
          <p>Adicione entradas em <code>src/content/blog</code>.</p>
        </div>
      )
    }
  </section>
</BaseLayout>