---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { withBase } from '../../lib/url';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) =>
    b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

console.log("TOTAL POSTS:", allPosts.length);

console.log(allPosts.map(p => ({
  title: p.data.title,
  category: p.data.category
})));

const engineering = allPosts.filter(
  (post) => post.data.category === 'engineering'
);

const research = allPosts.filter(
  (post) => post.data.category === 'research'
);

const theory = allPosts.filter(
  (post) => post.data.category === 'theory'
);

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('en', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  }).format(date);
---

<BaseLayout title="Blog" description="Notas técnicas e registros de pesquisa do Atlas.">
  <section class="page-head section">
    <p class="eyebrow">Notas técnicas</p>
    <h1>Caderno de pesquisa e registros de estudo.</h1>
    <p class="lead">
      Um espaço para documentar experimentos, ideias, cálculos e reflexões técnicas organizadas por área.
    </p>
  </section>

  <section class="section index-feed">
    <div class="section-heading">
      <p class="eyebrow">Engenharia</p>
      <h2>Notas de Engenharia</h2>
      <a class="text-link" href={withBase('/blog/')}>Ver todas</a>
    </div>

    {
      engineering.length > 0 ? (
        <div class="note-list">
          {engineering.map((post) => (
            <article class="note-row">
              <div>
                <p class="meta">{formatDate(post.data.publishDate)}</p>

                <h3>
                  <a href={withBase(`/blog/${post.id}/`)}>
                    {post.data.title}
                  </a>
                </h3>

                <p>{post.data.description}</p>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="empty-state compact">
          <p>Adicione notas de engenharia com <code>category: engineering</code>.</p>
        </div>
      )
    }
  </section>

  <section class="section index-feed">
    <div class="section-heading">
      <p class="eyebrow">Pesquisa</p>
      <h2>Notas de Pesquisa</h2>
      <a class="text-link" href={withBase('/blog/')}>Ver todas</a>
    </div>

    {
      research.length > 0 ? (
        <div class="note-list">
          {research.map((post) => (
            <article class="note-row">
              <div>
                <p class="meta">{formatDate(post.data.publishDate)}</p>

                <h3>
                  <a href={withBase(`/blog/${post.id}/`)}>
                    {post.data.title}
                  </a>
                </h3>

                <p>{post.data.description}</p>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="empty-state compact">
          <p>Adicione notas de pesquisa com <code>category: research</code>.</p>
        </div>
      )
    }
  </section>

  <section class="section index-feed">
    <div class="section-heading">
      <p class="eyebrow">Teoria</p>
      <h2>Notas de Teoria</h2>
      <a class="text-link" href={withBase('/blog/')}>Ver todas</a>
    </div>

    {
      theory.length > 0 ? (
        <div class="note-list">
          {theory.map((post) => (
            <article class="note-row">
              <div>
                <p class="meta">{formatDate(post.data.publishDate)}</p>

                <h3>
                  <a href={withBase(`/blog/${post.id}/`)}>
                    {post.data.title}
                  </a>
                </h3>

                <p>{post.data.description}</p>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="empty-state compact">
          <p>Adicione notas de teoria com <code>category: theory</code>.</p>
        </div>
      )
    }
  </section>
</BaseLayout>