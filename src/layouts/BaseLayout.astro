---
import '@fontsource-variable/fraunces/opsz.css';
import '@fontsource/public-sans/400.css';
import '@fontsource/public-sans/500.css';
import '@fontsource/public-sans/600.css';
import '@fontsource/public-sans/700.css';
import '@fontsource-variable/jetbrains-mono/wght.css';
import '../styles/global.css';
import { withBase } from '../lib/url';

interface Props {
  title?: string;
  description?: string;
  ogType?: 'website' | 'article';
  image?: string;
}

const siteName = 'Atlas';

const defaultDescription =
  'Portfólio técnico em engenharia elétrica, física experimental e sistemas embarcados.';

const {
  title = siteName,
  description = defaultDescription,
  ogType = 'website',
  image,
} = Astro.props;

const siteBase = Astro.site ?? new URL(Astro.url.origin);
const canonicalURL = new URL(Astro.url.pathname, siteBase);
const imageURL = image ? new URL(image, siteBase) : new URL(withBase('/og.jpg'), siteBase);
const fullTitle = title === siteName ? title : `${title} — ${siteName}`;

const navItems = [
  { href: '/', label: 'Início' },
  { href: '/about/', label: 'Sobre' },
  { href: '/works/', label: 'Projetos' },
  { href: '/blog/', label: 'Notas' },
];

const currentPath = Astro.url.pathname;
const isActive = (href: string) => {
  const full = withBase(href);
  return href === '/' ? currentPath === full : currentPath.startsWith(full);
};
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />

    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <link rel="icon" href={withBase('/favicon.ico')} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="sitemap" href={withBase('/sitemap-index.xml')} />
    <link rel="alternate" type="application/rss+xml" title={siteName} href={withBase('/rss.xml')} />

    <title>{fullTitle}</title>

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    {imageURL && <meta property="og:image" content={imageURL} />}

    <!-- Twitter -->
    <meta name="twitter:card" content={imageURL ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    {imageURL && <meta name="twitter:image" content={imageURL} />}

    <script is:inline>
      const storedTheme = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      document.documentElement.dataset.theme = storedTheme || (prefersDark ? 'dark' : 'light');
    </script>
  </head>

  <body>
    <header class="site-header">
      <a class="brand" href={withBase('/')} aria-label="Atlas home">
        <span class="brand-mark" aria-hidden="true"></span>
        <span>Atlas</span>
      </a>

      <nav class="site-nav" aria-label="Main navigation">
        {
          navItems.map((item) => (
            <a href={withBase(item.href)} aria-current={isActive(item.href) ? 'page' : undefined}>
              {item.label}
            </a>
          ))
        }
      </nav>

      <button class="theme-toggle" type="button" aria-label="Toggle color theme" data-theme-toggle>
        <span aria-hidden="true"></span>
      </button>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <p>Atlas — engenharia aplicada e documentação técnica.</p>
      <a href={withBase('/blog/')}>Notas</a>
    </footer>

    <script>
      const toggle = document.querySelector('[data-theme-toggle]');
      toggle?.addEventListener('click', () => {
        const current = document.documentElement.dataset.theme;
        const next = current === 'dark' ? 'light' : 'dark';
        document.documentElement.dataset.theme = next;
        localStorage.setItem('theme', next);
      });
    </script>
  </body>
</html>