{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "publishDate": {
      "type": "string",
      "format": "date-time"
    },
    "tags": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "description": {
      "type": "string"
    },
    "draft": {
      "default": false,
      "type": "boolean"
    },
    "heroImage": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "engineering",
        "research",
        "theory"
      ]
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "publishDate",
    "description",
    "category"
  ]
}